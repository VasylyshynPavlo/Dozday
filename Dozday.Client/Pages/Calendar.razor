@page "/"
@page "/calendar"
@using System.Text
@using System.Text.Json
@using Dozday.Core.Interfaces
@using Dozday.Core.DTOs
@rendermode InteractiveAuto
@inject IJSRuntime JS
@inject ICalendarEventService CalendarEventService

<PageTitle>Календар</PageTitle>

<CalendarView Events="events" OnRangeChanged="HandleRangeChangedAsync" />

@code {
    private IReadOnlyList<EventDto> events = [];
    private string? currentUserId;
    private CalendarRange? currentRange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await InitializeUserAsync();
        await LoadEventsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleRangeChangedAsync(CalendarRange range)
    {
        currentRange = range;
        await LoadEventsAsync();
    }

    private async Task InitializeUserAsync()
    {
        var token = await JS.InvokeAsync<string?>("auth.getToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            currentUserId = null;
            return;
        }

        currentUserId = TryGetUserIdFromToken(token);
    }

    private async Task LoadEventsAsync()
    {
        if (currentRange is null)
        {
            return;
        }

        if (!Guid.TryParse(currentUserId, out var userId))
        {
            events = [];
            return;
        }

        events = await CalendarEventService.GetSubscribedTeacherEventsAsync(userId, currentRange.Value.From, currentRange.Value.To);
    }

    private static string? TryGetUserIdFromToken(string token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return null;
        }

        var parts = token.Split('.');
        if (parts.Length < 2)
        {
            return null;
        }

        try
        {
            var payloadJson = Encoding.UTF8.GetString(Base64UrlDecode(parts[1]));
            using var json = JsonDocument.Parse(payloadJson);
            var root = json.RootElement;

            if (TryGetTokenClaim(root, "nameid", out var nameId))
            {
                return nameId;
            }

            if (TryGetTokenClaim(root, "sub", out var subject))
            {
                return subject;
            }

            if (TryGetTokenClaim(root, "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier",
                    out var claimNameId))
            {
                return claimNameId;
            }
        }
        catch
        {
            return null;
        }

        return null;
    }

    private static bool TryGetTokenClaim(JsonElement root, string name, out string? value)
    {
        value = null;

        if (root.TryGetProperty(name, out var element) && element.ValueKind == JsonValueKind.String)
        {
            value = element.GetString();
            return !string.IsNullOrWhiteSpace(value);
        }

        return false;
    }

    private static byte[] Base64UrlDecode(string input)
    {
        var normalized = input.Replace('-', '+').Replace('_', '/');
        var padding = normalized.Length % 4;
        if (padding == 2)
        {
            normalized += "==";
        }
        else if (padding == 3)
        {
            normalized += "=";
        }
        else if (padding != 0)
        {
            normalized = normalized.PadRight(normalized.Length + (4 - padding), '=');
        }

        return Convert.FromBase64String(normalized);
    }

}
