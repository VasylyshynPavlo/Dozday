@using System.Globalization
@using Dozday.Core.DTOs
@using Dozday.Core.Enums
@using Dozday.Core.Models
@using Dozday.Core.Utils
@using Microsoft.AspNetCore.Components
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable

<div class="calendar-day">
    @for (var minuteOffset = 0; minuteOffset <= MinutesInDayRange; minuteOffset += 60)
    {
        var column = minuteOffset == MinutesInDayRange
            ? minuteOffset + SideBufferColumn
            : minuteOffset + SideBufferColumn + 1;

        <div class="grid-vertical-lines" style="@($"grid-column: {column}; grid-row: 2;")"></div>
    }

    @for (var hour = DayStartHour; hour <= DayEndHour; hour++)
    {
        var minuteOffset = (hour - DayStartHour) * 60;
        var column = minuteOffset + SideBufferColumn + 1;
        <div class="time-label" style="@($"grid-row: 1; grid-column: {column};")">@($"{hour:00}:00")</div>
    }

    @if (currentTimeColumnStart is not null)
    {
        <div class="current-time-line" style="@($"grid-column: {currentTimeColumnStart.Value}; grid-row: 1 / -1;")"></div>
    }

    <div class="grid-horizontal-lines" style="grid-column: 1 / -1; grid-row: 2;"></div>

    @foreach (var viewEvent in dayEventViews)
    {
        <button type="button" class="event" style="@viewEvent.Style" @onclick="() => OpenEventDetails(viewEvent)">
            <div class="event__header">
                <span class="event__format" title="@GetEventTypeLabel(viewEvent.Event.Type)">@GetEventTypeIcon(viewEvent.Event.Type)</span>
                <span class="event__title">@viewEvent.Event.Summary</span>
            </div>
            <div class="event__time">@viewEvent.TimeText</div>
        </button>
    }

    @if (selectedEventView is not null)
    {
        <div class="event-details-backdrop" @onclick="CloseEventDetails">
            <div class="event-details" style="@GetEventDetailsStyle(selectedEventView)" @onclick:stopPropagation="true">
                <button type="button" class="event-details__close" @onclick="CloseEventDetails">✕</button>
                <h3 class="event-details__title">@selectedEventView.Event.Summary</h3>
                @if (!string.IsNullOrWhiteSpace(selectedEventView.Event.OrganizatorName))
                {
                    <div class="event-details__row"><strong>Викладач:</strong> @selectedEventView.Event.OrganizatorName</div>
                }
                <div class="event-details__row"><strong>Формат:</strong> @GetEventTypeLabel(selectedEventView.Event.Type)</div>
                <div class="event-details__row"><strong>Початок:</strong> @selectedEventView.Event.Start.ToString("dd.MM.yyyy HH:mm", culture)</div>
                <div class="event-details__row"><strong>Кінець:</strong> @selectedEventView.Event.End.ToString("dd.MM.yyyy HH:mm", culture)</div>
                @if (!string.IsNullOrWhiteSpace(selectedEventView.Event.Location))
                {
                    <div class="event-details__row"><strong>Локація:</strong> @selectedEventView.Event.Location</div>
                }
                @if (!string.IsNullOrWhiteSpace(selectedEventView.Event.Description))
                {
                    <div class="event-details__row"><strong>Опис:</strong> @selectedEventView.Event.Description</div>
                }
                @if (!string.IsNullOrWhiteSpace(selectedEventView.Event.MeetingLink))
                {
                    <div class="event-details__row"><a href="@selectedEventView.Event.MeetingLink" target="_blank" rel="noopener noreferrer">Посилання на зустріч</a></div>
                }
                <div class="event-details__row"><strong>Планують прийти: </strong> @selectedEventView.Event.Subscribers</div>
                                <button type="button" class="event-details-button" @onclick="ToggleEventSubscriptionAsync" disabled="@isSubscriptionLoading">
                    @(isSubscribed ? "Не планую прийти" : "Планую прийти")
                </button>
                <div class="event-details__row" style="opacity: 0.5; font-size: 10px; bottom: -5px; position: absolute; font-style: italic;"><strong>Ідентифікатор:</strong> @selectedEventView.Event.Id</div>
            </div>
        </div>
    }
</div>

@code {
    private const int DayStartHour = 8;
    private const int DayEndHour = 22;
    private const int MinutesInDayRange = (DayEndHour - DayStartHour) * 60;
    private const int SideBufferColumn = 1;

    [Parameter]
    public DateOnly Day { get; set; } = DateOnly.FromDateTime(DateTime.Now);

    [Parameter]
    public IReadOnlyList<EventDto> Events { get; set; } = [];

    private int? currentTimeColumnStart;
    private PeriodicTimer? timeTicker;
    private CancellationTokenSource? timeTickerCts;
    private readonly CultureInfo culture = new("uk-UA");
    private readonly List<DayEventView> dayEventViews = [];
    private DayEventView? selectedEventView;
    private bool isSubscribed;
    private bool isSubscriptionLoading;

    protected override void OnInitialized()
    {
        BuildDayEventViews();
        UpdateCurrentTimeIndicator();
        _ = StartTimeTickerAsync();
    }

    protected override void OnParametersSet()
    {
        BuildDayEventViews();
        UpdateCurrentTimeIndicator();
    }

    private void BuildDayEventViews()
    {
        dayEventViews.Clear();

        var dayStart = Day.ToDateTime(new TimeOnly(DayStartHour, 0));
        var dayEnd = Day.ToDateTime(new TimeOnly(DayEndHour, 0));

        var rowIndex = 0;

        foreach (var calendarEvent in Events.OrderBy(x => x.Start))
        {
            if (calendarEvent.End <= calendarEvent.Start)
            {
                continue;
            }

            var eventStartDate = DateOnly.FromDateTime(calendarEvent.Start);
            var eventEndDate = DateOnly.FromDateTime(calendarEvent.End);
            if (Day < eventStartDate || Day > eventEndDate)
            {
                continue;
            }

            var segmentStart = calendarEvent.Start > dayStart ? calendarEvent.Start : dayStart;
            var segmentEnd = calendarEvent.End < dayEnd ? calendarEvent.End : dayEnd;

            if (segmentEnd <= segmentStart)
            {
                continue;
            }

            var startMinute = Math.Clamp((int)(segmentStart - dayStart).TotalMinutes, 0, MinutesInDayRange);
            var endMinute = Math.Clamp((int)Math.Ceiling((segmentEnd - dayStart).TotalMinutes), 0, MinutesInDayRange);
            if (endMinute <= startMinute)
            {
                endMinute = Math.Min(MinutesInDayRange, startMinute + 1);
            }

            var columnStart = SideBufferColumn + 1 + startMinute;
            var columnEnd = SideBufferColumn + 1 + endMinute;

            dayEventViews.Add(new DayEventView(
                calendarEvent,
                $"{segmentStart:HH:mm} • {segmentEnd:HH:mm}",
                BuildEventStyle(calendarEvent, columnStart, columnEnd, rowIndex)));

            rowIndex++;
        }
    }

    private void UpdateCurrentTimeIndicator()
    {
        var now = DateTime.Now;

        if (DateOnly.FromDateTime(now) != Day)
        {
            currentTimeColumnStart = null;
            return;
        }

        var currentMinute = now.Hour * 60 + now.Minute - DayStartHour * 60;

        if (currentMinute < 0 || currentMinute > MinutesInDayRange)
        {
            currentTimeColumnStart = null;
            return;
        }

        currentTimeColumnStart = SideBufferColumn + 1 + currentMinute;
    }

    private static string GetEventTypeIcon(EventType type) => CalendarEventUtils.GetEventTypeIcon(type);

    private static string GetEventTypeLabel(EventType type) => CalendarEventUtils.GetEventTypeLabel(type);

    private void OpenEventDetails(DayEventView viewEvent)
    {
        selectedEventView = viewEvent;
        _ = LoadSubscriptionStatusAsync();
    }

    private void CloseEventDetails()
    {
        selectedEventView = null;
        isSubscribed = false;
        isSubscriptionLoading = false;
    }

    private static string BuildEventStyle(EventDto calendarEvent, int columnStart, int columnEnd, int rowIndex)
    {
        return $"grid-column: {columnStart} / {columnEnd}; " +
               "grid-row: 2; " +
               $"--event-row-index: {rowIndex}; " +
               CalendarEventUtils.BuildEventColorStyle(calendarEvent);
    }

    private async Task LoadSubscriptionStatusAsync()
    {
        if (selectedEventView is null)
        {
            return;
        }

        isSubscriptionLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await JS.InvokeAsync<string?>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                isSubscribed = false;
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.GetAsync($"api/UserEventSubscription/status?eventId={Uri.EscapeDataString(selectedEventView.Event.Id)}");
            if (!response.IsSuccessStatusCode)
            {
                isSubscribed = false;
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<bool>();
            isSubscribed = result;
        }
        finally
        {
            isSubscriptionLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleEventSubscriptionAsync()
    {
        if (selectedEventView is null)
        {
            return;
        }

        isSubscriptionLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await JS.InvokeAsync<string?>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsync($"api/UserEventSubscription/toggle?eventId={Uri.EscapeDataString(selectedEventView.Event.Id)}", null);
            if (!response.IsSuccessStatusCode)
            {
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<bool>();
            isSubscribed = result;
        }
        finally
        {
            isSubscriptionLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetEventDetailsStyle(DayEventView viewEvent)
    {
        return CalendarEventUtils.BuildEventDetailsStyle(viewEvent.Event);
    }

    private async Task StartTimeTickerAsync()
    {
        timeTickerCts = new CancellationTokenSource();
        timeTicker = new PeriodicTimer(TimeSpan.FromSeconds(15));

        try
        {
            while (await timeTicker.WaitForNextTickAsync(timeTickerCts.Token))
            {
                UpdateCurrentTimeIndicator();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public void Dispose()
    {
        timeTickerCts?.Cancel();
        timeTicker?.Dispose();
        timeTickerCts?.Dispose();
    }

    private sealed record DayEventView(EventDto Event, string TimeText, string Style);
}