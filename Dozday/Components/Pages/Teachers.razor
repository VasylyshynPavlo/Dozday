@page "/teachers"
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using Dozday.Core.DTOs
@using Dozday.Core.Interfaces
@using Dozday.Services.Services
@inject IUserService userService
@attribute [StreamRendering]
@inject IJSRuntime JS
@inject GlobalStorageService GlobalStorageService

<PageTitle>Викладачі</PageTitle>

<div class="bg">
    <form class="search-bar w-60p-adaptive" @onsubmit="HandleSearch" @onsubmit:preventDefault>
        <input type="text"
                placeholder="Введіть ім'я або прізвище викладача"
                @bind="searchTerm"
                @bind:event="oninput"/>
        <button type="submit">
            <span>Знайти</span>
        </button>
    </form>
    <div class="search-result">
        @foreach (var t in teachers)
        {
            <div class="card">
                <div class="search-result--block--avatar">
                    <img src="@GetAvatarUrl(t.Item1.AvatarUrl)"
                            alt="Avatar"
                            referrerpolicy="no-referrer"
                            onerror="this.onerror=null;this.src='https://placehold.co/100?text=Avatar';"/>
                </div>
                <h5>
                    @t.Item1.FullName
                </h5>
                <button type="button"
                        class="button"
                        @onclick="() => ChangeSubStatusAsync(t.Item2, t.Item1.Id)">
                    @(t.Item2 ? "Не слідкувати" : "Слідкувати")
                </button>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="search-pagination">
            <button type="button" class="button @(page <= 1 ? "button-unactive" : null)" @onclick="() => GoToPageAsync(1)"
                    disabled="@(page <= 1)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 17l-5-5 5-5M11 17l-5-5 5-5" />
                </svg>
            </button>
            <button type="button" class="button @(page <= 1 ? "button-unactive" : null)" @onclick="() => GoToPageAsync(page - 1)"
                    disabled="@(page <= 1)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 17l-5-5 5-5" />
                </svg>
            </button>

            @foreach (var pageNumber in GetVisiblePages())
            {
                <button type="button"
                        class="button @(pageNumber == page ? "search-pagination__page--active" : string.Empty)"
                        @onclick="() => GoToPageAsync(pageNumber)">
                    @pageNumber
                </button>
            }

            <button type="button" class="button @(page >= totalPages ? "button-unactive" : null)" @onclick="() => GoToPageAsync(page + 1)"
                    disabled="@(page >= totalPages)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 17l5-5-5-5" />
                </svg>
            </button>
            <button type="button" class="button @(page >= totalPages ? "button-unactive" : null)" @onclick="() => GoToPageAsync(totalPages)"
                    disabled="@(page >= totalPages)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 17l5-5-5-5M13 17l5-5-5-5" />
                </svg>
            </button>
        </div>
    }

    @if (_isLoading)
    {
        <div class="teachers-loading-overlay">
            <LoadingIndicator/>
        </div>
    }
</div>

@code {
    private const string DefaultAvatarUrl = "https://placehold.co/100?text=Avatar";
    private List<(UserIdNameAvatarDto, bool)> teachers = [];
    string searchTerm = string.Empty;
    int page = 1;
    readonly int pageSize = 12;
    int totalPages = -1;
    private string? currentUserId;
    private bool _isLoading;

    protected override void OnInitialized()
    {
        GlobalStorageService.OnTokenChanged += OnTokenChanged;
    }

    private async void OnTokenChanged()
    {
        currentUserId = GlobalStorageService.UserId;
        await LoadTeachersAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GlobalStorageService.OnTokenChanged -= OnTokenChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }
    }

    private async Task HandleSearch()
    {
        page = 1;
        await LoadTeachersAsync();
    }

    private async Task GoToPageAsync(int targetPage)
    {
        if (targetPage < 1 || (totalPages > 0 && targetPage > totalPages) || targetPage == page)
        {
            return;
        }

        page = targetPage;
        await LoadTeachersAsync();
    }

    private async Task LoadTeachersAsync()
    {
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            teachers = [];
            totalPages = -1;
            _isLoading = false;
            
        }

        try
        {
            var query = string.IsNullOrWhiteSpace(searchTerm) ? string.Empty : searchTerm.Trim();
            if (currentUserId == null)
            {
                Console.WriteLine("Current user ID is null. Cannot load teachers.");
                return;
            }
            var result = await userService.GetTeacherShortIfoWithSubStatusAsync(currentUserId, page, pageSize, query);
            teachers = result.Items;
            totalPages = result.TotalCount <= pageSize ? -1 : result.TotalPages;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetAvatarUrl(string? avatarUrl)
    {
        if (string.IsNullOrWhiteSpace(avatarUrl))
        {
            return DefaultAvatarUrl;
        }

        var normalized = avatarUrl.Trim().Trim('"');
        return Uri.TryCreate(normalized, UriKind.Absolute, out var uri)
               && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps)
            ? normalized
            : DefaultAvatarUrl;
    }

    private IEnumerable<int> GetVisiblePages()
    {
        if (totalPages <= 1)
        {
            return [];
        }

        var pages = new SortedSet<int> { page, totalPages };

        if (page - 2 > 0)
        {
            pages.Add(page - 2);
        }

        if (page - 1 > 0)
        {
            pages.Add(page - 1);
        }

        if (page + 1 <= totalPages)
        {
            pages.Add(page + 1);
        }

        if (page + 2 <= totalPages)
        {
            pages.Add(page + 2);
        }


        return pages;
    }

    private async Task ChangeSubStatusAsync(bool sub, string teacherId)
    {
        if (string.IsNullOrWhiteSpace(currentUserId)) return;
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (sub)
            {
                await userService.UnSubscribeUserAsync(currentUserId, teacherId);
            }
            else
            {
                await userService.SubscribeUserAsync(currentUserId, teacherId);
            }

            var teacherIndex = teachers.FindIndex(t => t.Item1.Id == teacherId);
            if (teacherIndex >= 0)
            {
                var current = teachers[teacherIndex];
                teachers[teacherIndex] = (current.Item1, !current.Item2);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

}
