@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using Dozday.Core.Enums
@using Dozday.Services.Services
@implements IDisposable

<div class="nav-menu @(_isMenuOpen ? "nav-menu-open" : string.Empty)">
    
    <button type="button" class="nav-menu-toggle" @onclick="ToggleMenu" aria-expanded="@_isMenuOpen" aria-label="Меню">☰</button>

    <div class="nav-menu-links">
        <a href="/calendar" class="nav-menu-link @(IsActive("calendar") ? "nav-menu-link-active" : string.Empty)">
            <div class="nav-menu-link-text @(IsActive("calendar") ? "nav-menu-link-text-active" : string.Empty)">Календар
            </div>
        </a>
        <a href="/teachers" class="nav-menu-link @(IsActive("teachers") ? "nav-menu-link-active" : string.Empty)">
            <div class="nav-menu-link-text @(IsActive("teachers") ? "nav-menu-link-text-active" : string.Empty)">Викладачі
            </div>
        </a>
        <a href="/help" class="nav-menu-link @(IsActive("help") ? "nav-menu-link-active" : string.Empty)">
            <div class="nav-menu-link-text @(IsActive("help") ? "nav-menu-link-text-active" : string.Empty)">Допомога</div>
        </a>
        @if (_isTeacher)
        {
            <a href="/teacher-panel"
               class="nav-menu-link @(IsActive("teacher-panel") ? "nav-menu-link-active" : string.Empty)">
                <div class="nav-menu-link-text @(IsActive("teacher-panel") ? "nav-menu-link-text-active" : string.Empty)">
                    Панель викладача
                </div>
            </a>
        }
        @if (_isAdmin)
        {
            <a href="/admin/admin-panel"
               class="nav-menu-link @(IsActive("admin-panel") ? "nav-menu-link-active" : string.Empty)">
                <div class="nav-menu-link-text @(IsActive("admin-panel") ? "nav-menu-link-text-active" : string.Empty)">
                    Панель адміністратора
                </div>
            </a>
        }
    </div>

    <div class="nav-menu-actions">
        <a href="#">
            <div class="nav-menu-user">
                <img class="nav-menu-user-avatar" src="@_avatarUrl" alt="Avatar" />
                @_userName
            </div>
        </a>
        <button type="button" class="nav-menu-link nav-menu-logout" @onclick="LogoutAsync">Вийти</button>
    </div>
</div>

@code {
    private const string DefaultAvatarUrl = "https://placehold.co/100?text=Placeholder&font=roboto";
    private string _avatarUrl = DefaultAvatarUrl;
    private bool _isAdmin;
    private bool _isTeacher;
    private bool _isMenuOpen;
    private string _userName = string.Empty;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadUserFromTokenAsync();
        StateHasChanged();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isMenuOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleMenu()
    {
        _isMenuOpen = !_isMenuOpen;
    }

    private bool IsActive(string page)
    {
        var relativePath = GetRelativePath();
        return page == "calendar"
            ? string.IsNullOrWhiteSpace(relativePath) || relativePath == "calendar"
            : relativePath.Contains(page);
    }

    private string GetCurrentPageTitle()
    {
        var relativePath = GetRelativePath();

        if (string.IsNullOrWhiteSpace(relativePath) || relativePath == "calendar")
        {
            return "Календар";
        }

        if (relativePath.Contains("teachers"))
        {
            return "Викладачі";
        }

        if (relativePath.Contains("help"))
        {
            return "Допомога";
        }

        if (relativePath.Contains("admin-panel"))
        {
            return "Панель адміністратора";
        }

        return "Dozday";
    }

    private string GetRelativePath()
    {
        return Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant();
    }

    private async Task LoadUserFromTokenAsync()
    {
        var token = await JS.InvokeAsync<string?>("auth.getToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            _avatarUrl = DefaultAvatarUrl;
            _isAdmin = false;
            _isTeacher = false;
            _userName = string.Empty;
            return;
        }

        try
        {
            var jwt = new JwtSecurityTokenHandler().ReadJwtToken(token);
            _avatarUrl = jwt.Claims.FirstOrDefault(c => c.Type == "avatar")?.Value ?? DefaultAvatarUrl;
            _userName = jwt.Claims.FirstOrDefault(c => c.Type == "unique_name")?.Value ?? "error";
            var roleClaim = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role || c.Type == "role" || c.Type == "roles");
            _isAdmin = IsAdministrator(roleClaim?.Value);
            _isTeacher = IsTeacher(roleClaim?.Value);
        }
        catch
        {
            _avatarUrl = DefaultAvatarUrl;
            _isAdmin = false;
            _isTeacher = false;
        }
    }

    private async Task LogoutAsync()
    {
        await JS.InvokeVoidAsync("auth.clearToken");
        Navigation.NavigateTo("/auth", true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static bool IsAdministrator(string? roleValue)
    {
        if (string.IsNullOrWhiteSpace(roleValue))
        {
            return false;
        }

        if (Enum.TryParse<UserRoles>(roleValue, out var roles))
        {
            return roles.HasFlag(UserRoles.Administrator);
        }

        return int.TryParse(roleValue, out var numericRole)
               && ((UserRoles)numericRole).HasFlag(UserRoles.Administrator);
    }

    private static bool IsTeacher(string? roleValue)
    {
        if (string.IsNullOrWhiteSpace(roleValue))
        {
            return false;
        }

        if (Enum.TryParse<UserRoles>(roleValue, out var roles))
        {
            return roles.HasFlag(UserRoles.Teacher);
        }

        return int.TryParse(roleValue, out var numericRole)
               && ((UserRoles)numericRole).HasFlag(UserRoles.Teacher);
    }

}
